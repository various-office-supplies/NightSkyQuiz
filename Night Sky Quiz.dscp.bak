  <TextBlock Text="Night Sky Quiz" FontSize="48" TextAlignment="Left" TextWrapping="NoWrap" Width="320" MaxWidth="2010" Height="80" MaxHeight="1388" Canvas.Left="30" Canvas.Top="300" />
  <esdguilc:ExtendedButton BackgroundImageStretch="Uniform" CornerRadius="5,5,5,5" BorderBrush2="#FFACACAC" TextAlignment="Center" TextWrapping="NoWrap" BorderBrush="#FFA4E206" BorderThickness="3,3,3,3" Background="#FF457E19" FontSize="36" Name="ExtendedButton_e04f180955dc4dd9b2008f1ebadd0fea" Width="300" MaxWidth="2010" Height="100" MaxHeight="1388" ToolTip="{x:Null}" Canvas.Left="30" Canvas.Top="410">
    <esdguilc:ExtendedButton.Tag>
      <esdguicp:ExecuteHostStringCommand>
        <esdguicp:ExecuteHostStringCommand.StringCommands>
          <x:Array Type="s:String">
            <s:String>script play $Content\User\Downloads\MesaCC\Night Sky Quiz\Scripts\NightSkyQuizJS.ds</s:String>
          </x:Array>
        </esdguicp:ExecuteHostStringCommand.StringCommands>
      </esdguicp:ExecuteHostStringCommand>
    </esdguilc:ExtendedButton.Tag>Start Quiz</esdguilc:ExtendedButton>
  <esdguilc:ExtendedButton BackgroundImageStretch="Uniform" CornerRadius="5,5,5,5" TextAlignment="Center" TextWrapping="NoWrap" BorderBrush="#FFE80C40" BorderThickness="3,3,3,3" Background="#FF680925" FontSize="36" Name="ExtendedButton_a5fa9799eaf2495ca999533656598251" Width="300" MaxWidth="2010" Height="100" MaxHeight="1388" Canvas.Left="30" Canvas.Top="560">
    <esdguilc:ExtendedButton.Tag>
      <esdguicp:ExecuteHostStringCommand>
        <esdguicp:ExecuteHostStringCommand.StringCommands>
          <x:Array Type="s:String">
